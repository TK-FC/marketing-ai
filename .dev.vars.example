# Copy to `.dev.vars` for `wrangler dev`. NEVER commit `.dev.vars` (it is gitignored).
# In production these are set with `wrangler secret put <NAME>` - never in wrangler.toml, never in code.

ANTHROPIC_API_KEY="sk-ant-..."
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Any long random string. Generate one with: openssl rand -hex 32
GATE_SIGNING_SECRET="replace-with-a-long-random-secret"
