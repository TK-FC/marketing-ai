{
  "name": "marketing-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Foodie Coaches member-facing Marketing AI - a grounded hospitality marketing chatbot served from a Cloudflare Worker.",
  "scripts": {
    "build": "node scripts/build-prompt.mjs",
    "dev": "npm run build && wrangler dev",
